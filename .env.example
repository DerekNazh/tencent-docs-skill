# 腾讯文档 API 凭证
# 复制此文件为 .env 并填入你的凭证

# 账号1
TENCENTDOCS1_ACCESS_TOKEN=your_access_token_here
TENCENTDOCS1_CLIENT_ID=your_client_id_here
TENCENTDOCS1_OPEN_ID=your_open_id_here

# 账号2（可选）
TENCENTDOCS2_ACCESS_TOKEN=your_access_token_here
TENCENTDOCS2_CLIENT_ID=your_client_id_here
TENCENTDOCS2_OPEN_ID=your_open_id_here

# 默认指向账号1
TENCENTDOCS_ACCESS_TOKEN=your_access_token_here
TENCENTDOCS_CLIENT_ID=your_client_id_here
TENCENTDOCS_OPEN_ID=your_open_id_here
